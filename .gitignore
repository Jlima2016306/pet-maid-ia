```gitignore
# =========================
# Dependencies
# =========================
node_modules/

# =========================
# Environment variables
# =========================
.env
.env.*
!.env.example

# =========================
# Firebase / Google Cloud
# =========================
credentials/
firebase-key.json
serviceAccountKey.json
*.pem
*.p12
*.key

# =========================
# Logs
# =========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Build
# =========================
dist/
build/
coverage/
.tmp/
temp/

# =========================
# Cache
# =========================
.cache/
.parcel-cache/
.eslintcache

# =========================
# IDE
# =========================
.vscode/
.idea/
*.swp
*.swo

# =========================
# Operating System
# =========================
.DS_Store
Thumbs.db
desktop.ini

# =========================
# Misc
# =========================
*.pid
*.seed
```
